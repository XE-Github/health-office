{
  "name": "health-office",
  "private": true,
  "version": "0.0.0",
  "description": "健康办公桌面办公健康微干预系统。",
  "author": "Codex Demo",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "desktop:build": "npm run build && electron-builder --win portable --x64",
    "desktop:dir": "npm run build && electron-builder --dir --win --x64",
    "desktop:run": "npm run build && electron electron/main.cjs",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:side-screen": "node --experimental-strip-types scripts/side-screen-regression.mjs",
    "smoke": "node scripts/smoke-ui.cjs",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run smoke"
  },
  "build": {
    "appId": "com.codex.health-office",
    "artifactName": "健康办公-${version}-portable.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "productName": "健康办公",
    "win": {
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "puppeteer-core": "^24.9.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.5",
    "wait-on": "^9.0.4"
  }
}
